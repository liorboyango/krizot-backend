// Prisma Schema for Krizot Application
// Database: PostgreSQL
// ORM: Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// User roles for RBAC
enum Role {
  ADMIN
  MANAGER
}

/// Station status
enum StationStatus {
  ACTIVE
  CLOSED
}

/// User model - represents shift managers and admins
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   /// bcrypt hashed password
  name      String
  role      Role     @default(MANAGER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Schedules assigned to this user
  schedules Schedule[]

  /// Refresh tokens for JWT rotation
  refreshTokens RefreshToken[]

  @@index([email])
  @@index([role])
  @@map("users")
}

/// RefreshToken model - for JWT refresh token blacklisting/rotation
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

/// Station model - represents a work station/post
model Station {
  id        String        @id @default(uuid())
  name      String
  location  String
  capacity  Int           @default(1) /// Max staff slots
  status    StationStatus @default(ACTIVE)
  notes     String?       /// Optional notes about the station
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  /// Schedules for this station
  schedules Schedule[]

  @@index([status])
  @@index([name])
  @@map("stations")
}

/// Schedule model - represents a shift assignment
model Schedule {
  id        String   @id @default(uuid())
  stationId String
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  startTime DateTime
  endTime   DateTime
  notes     String?  /// Optional shift notes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stationId])
  @@index([userId])
  @@index([startTime, endTime])
  @@index([stationId, startTime, endTime])
  @@map("schedules")
}
