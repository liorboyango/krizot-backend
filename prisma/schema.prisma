// Prisma Schema for Krizot Application
// Defines data models for users, stations, and schedules

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// User roles for RBAC
enum Role {
  ADMIN
  MANAGER
}

/// Station status
enum StationStatus {
  ACTIVE
  CLOSED
  MAINTENANCE
}

/// Schedule status
enum ScheduleStatus {
  OPEN
  ASSIGNED
  COVERED
  CRITICAL
  CANCELLED
}

/// User model - represents shift managers and admins
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  role      Role     @default(MANAGER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  schedules     Schedule[]     @relation("UserSchedules")
  refreshTokens RefreshToken[]

  @@index([email])
  @@index([role])
  @@map("users")
}

/// Station model - represents operational stations/posts
model Station {
  id        String        @id @default(uuid())
  name      String
  location  String
  capacity  Int           @default(1)
  status    StationStatus @default(ACTIVE)
  notes     String?       @db.Text
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  // Relations
  schedules Schedule[]

  @@index([status])
  @@index([name])
  @@map("stations")
}

/// Schedule model - represents shift assignments
model Schedule {
  id        String         @id @default(uuid())
  stationId String         @map("station_id")
  userId    String?        @map("user_id")
  startTime DateTime       @map("start_time")
  endTime   DateTime       @map("end_time")
  status    ScheduleStatus @default(OPEN)
  notes     String?        @db.Text
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  // Relations
  station Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  user    User?    @relation("UserSchedules", fields: [userId], references: [id], onDelete: SetNull)

  @@index([stationId])
  @@index([userId])
  @@index([startTime, endTime])
  @@index([status])
  @@map("schedules")
}

/// RefreshToken model - for JWT refresh token management
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
