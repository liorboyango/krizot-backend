# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/krizot_db?schema=public"

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Access token secret (15 minute expiry) - use a strong random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Refresh token secret (7 day expiry) - use a DIFFERENT strong random string
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: error, warn, info, debug
LOG_LEVEL=debug
