# ============================================================
# Krizot Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/krizot_dev

# ── JWT Authentication ────────────────────────────────────
# Must be at least 32 characters. Use: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate Limiting ─────────────────────────────────────────
# Window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window per IP (global)
RATE_LIMIT_MAX_REQUESTS=100
# Max auth attempts per window per IP
AUTH_RATE_LIMIT_MAX=10

# ── Logging ───────────────────────────────────────────────
# Levels: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
# Format: json (production) | pretty (development)
LOG_FORMAT=pretty

# ── Security ──────────────────────────────────────────────
# bcrypt rounds (10-14 recommended; higher = slower but more secure)
BCRYPT_ROUNDS=12

# ── Redis (Optional) ─────────────────────────────────────
# Used for token blacklist and caching. Leave empty to disable.
# REDIS_URL=redis://localhost:6379
