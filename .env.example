# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/krizot_db?schema=public

# ─── JWT Authentication ────────────────────────────────────────────────────────
# Access token secret (min 32 chars, use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
# Access token expiry (e.g., 15m, 1h)
JWT_EXPIRES_IN=15m
# Refresh token secret (different from access token secret)
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
# Refresh token expiry (e.g., 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max requests per minute per IP
RATE_LIMIT_MAX=100

# ─── Seeding (Development Only) ───────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@krizot.com
SEED_ADMIN_PASSWORD=Admin@123456
