# ============================================================
# Krizot Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Firebase ──────────────────────────────────────────────
# Full Firebase service-account JSON, inline (single line, escaped).
# Generate one at: Firebase Console → Project Settings → Service accounts → Generate new private key
# Tip: jq -c . path/to/serviceAccount.json | sed 's/"/\\"/g'
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Firebase Web API key — found at: Firebase Console → Project Settings → General → Web API Key
# Used server-side to call the Identity Toolkit signInWithPassword & secure-token endpoints.
FIREBASE_API_KEY=your_firebase_web_api_key_here

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=pretty
